{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Blueprint Pedagógico",
  "description": "Formato intermediário entre material bruto e revisão JSON final. Preenchido pelo autor com revisão humana antes de gerar o draft.",
  "type": "object",
  "required": [
    "blueprintVersion",
    "targetRevision",
    "sourceSummary",
    "learningObjectives",
    "missions",
    "humanReview"
  ],
  "properties": {
    "blueprintVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "Versão do schema de blueprint. Atualmente: '1.0'."
    },
    "targetRevision": {
      "type": "object",
      "required": ["revisionSlug", "title", "grade", "subject", "description"],
      "properties": {
        "revisionSlug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "title": { "type": "string" },
        "grade": { "type": "string" },
        "subject": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "sourceSummary": {
      "type": "object",
      "required": ["sourceId", "scope", "copyrightRisk"],
      "properties": {
        "sourceId": { "type": "string" },
        "scope": { "type": "string", "description": "Quais tópicos/páginas foram usados como referência." },
        "copyrightRisk": { "type": "string", "enum": ["low", "medium", "high"] },
        "notes": { "type": "string" }
      }
    },
    "learningObjectives": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "missions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slug", "title", "shortTitle", "goal", "estimatedMinutes", "concepts", "workedExamples", "questionPlan"],
        "properties": {
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "shortTitle": { "type": "string" },
          "goal": { "type": "string" },
          "estimatedMinutes": { "type": "integer", "minimum": 1, "maximum": 30 },
          "prerequisites": { "type": "array", "items": { "type": "string" } },
          "concepts": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "workedExamples": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["problem", "steps", "conclusion"],
              "properties": {
                "problem": { "type": "string" },
                "steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
                "conclusion": { "type": "string" }
              }
            }
          },
          "questionPlan": {
            "type": "object",
            "required": ["minimumQuestions", "difficulties", "skills"],
            "properties": {
              "minimumQuestions": { "type": "integer", "minimum": 5 },
              "difficulties": {
                "type": "array",
                "items": { "type": "string", "enum": ["basic", "intermediate", "challenge"] }
              },
              "skills": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "commonErrors": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "humanReview": {
      "type": "object",
      "required": ["pedagogicalReviewRequired", "copyrightReviewRequired", "approved"],
      "properties": {
        "pedagogicalReviewRequired": { "type": "boolean" },
        "copyrightReviewRequired": { "type": "boolean" },
        "approved": { "type": "boolean" },
        "reviewer": { "type": ["string", "null"] },
        "reviewDate": { "type": ["string", "null"] }
      }
    }
  }
}
