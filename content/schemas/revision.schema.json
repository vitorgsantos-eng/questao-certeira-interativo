{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContentRevision",
  "description": "Schema v1.0 — pacote de revisão do motor Questão Certeira.",
  "type": "object",
  "required": ["schemaVersion", "revisionSlug", "title", "grade", "description", "missions"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "Versão do schema. Atualmente: '1.0'."
    },
    "revisionSlug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string" },
    "grade": { "type": "string" },
    "subject": { "type": "string" },
    "description": { "type": "string" },
    "visualConfig": {
      "type": "object",
      "properties": {
        "subtitle": { "type": "string" },
        "subject": { "type": "string" },
        "tone": { "type": "string" },
        "missionMapBadge": { "type": "string" }
      }
    },
    "missions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slug", "title", "shortTitle", "goal", "estimatedMinutes", "blocks", "questions"],
        "properties": {
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "shortTitle": { "type": "string" },
          "goal": { "type": "string" },
          "estimatedMinutes": { "type": "integer", "minimum": 1, "maximum": 30 },
          "isOptional": { "type": "boolean" },
          "prerequisites": { "type": "array", "items": { "type": "string" } },
          "blocks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["intro", "concept", "visual_explanation", "worked_example", "hint", "summary", "diagram"]
                }
              }
            }
          },
          "questions": {
            "type": "array",
            "minItems": 5,
            "items": {
              "type": "object",
              "required": ["type", "difficulty", "skillTag", "statement"],
              "properties": {
                "type": { "type": "string", "enum": ["multiple_choice", "numeric"] },
                "difficulty": { "type": "string", "enum": ["basic", "intermediate", "challenge"] },
                "skillTag": { "type": "string" },
                "statement": { "type": "string" }
              }
            }
          },
          "challengeQuestions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "difficulty", "skillTag", "statement"],
              "properties": {
                "type": { "type": "string", "enum": ["multiple_choice", "numeric"] },
                "difficulty": { "type": "string", "enum": ["challenge"] },
                "skillTag": { "type": "string" },
                "statement": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
