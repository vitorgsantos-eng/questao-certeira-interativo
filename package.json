{
  "name": "questao-certeira-interativo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "validate-content": "tsx scripts/validate-content.ts",
    "validate-content:ci": "tsx scripts/validate-content.ts content/revisions/revisao-9ano-triangulos-sistemas.json",
