    "@supabase/supabase-js": "^2.45.4",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "katex": "^0.17.0",
    "next": "15.5.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/katex": "^0.16.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "eslint": "^8",
    "eslint-config-next": "15.5.19",
