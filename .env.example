# Supabase — obter em https://supabase.com (plano gratuito)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave pública do Supabase — use uma das duas formas abaixo (ambas são suportadas):
# - Supabase Dashboard > Project Settings > API > "Publishable key" (nome atual)
# - Ou "anon / public" (nome anterior — ainda funciona)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   ← alternativa equivalente

# Chave de serviço — NUNCA expor no frontend; usar apenas em rotas server-side
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Código de acesso do professor — escolha uma senha forte e única
PROFESSOR_ACCESS_CODE=codigo-professor-seguro-aqui

# Segredo para cookies de sessão (mínimo 32 chars; gere com: openssl rand -base64 32)
SESSION_SECRET=gere-um-segredo-forte-aqui-32-chars-minimo
