# Supabase — obter em https://supabase.com (plano gratuito)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Chave de serviço — NUNCA expor no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Código de acesso do professor — escolha uma senha forte
PROFESSOR_ACCESS_CODE=codigo-professor-seguro-aqui

# Segredo para cookies de sessão (gere com: openssl rand -base64 32)
SESSION_SECRET=gere-um-segredo-forte-aqui-32-chars-minimo
